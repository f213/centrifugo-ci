{
  "client": {
    "token": {
      "hmac_secret_key": "{{ .Env.CENTRIFUGO_SECRET }}",
      "user_id_claim": "user_id"
    },
    "allowed_origins": [
      {{- $first := true }}
      {{- range (getenv "CENTRIFUGO_ALLOWED_ORIGINS" "" | strings.Split ",") }}
      {{- $origin := strings.TrimSpace . }}
      {{- if ne $origin "" }}
      {{- if not $first }},{{ end }}
      "{{ $origin }}"
      {{- $first = false }}
      {{- end }}
      {{- end }}
    ],
    "subscribe_to_user_personal_channel": {
      "enabled": true,
      "personal_channel_namespace": "{{ .Env.CENTRIFUGO_PERSONAL_NAMESPACE }}"
    }
  },
  "channel": {
    "namespaces": [
      {
        "name": "{{ .Env.CENTRIFUGO_PERSONAL_NAMESPACE }}",
        "presence": true,
        "allow_user_limited_channels": true
      }
      {{- range (getenv "CENTRIFUGO_ADDITIONAL_PERSONAL_NAMESPACES" "" | strings.Split ",") }}
      {{- $ns := strings.TrimSpace . }}
      {{- if ne $ns "" }},
      {
        "name": "{{ $ns }}",
        "presence": true,
        "allow_user_limited_channels": true
      }
      {{- end }}
      {{- end }},
      {
        "name": "public"
      }
    ]
  },
  "admin": {
    "enabled": true,
    "password": "{{ .Env.CENTRIFUGO_ADMIN_PASSWORD }}",
    "secret": "{{ .Env.CENTRIFUGO_SECRET }}"
  },
  "http_api": {
    "key": "{{ .Env.CENTRIFUGO_SECRET }}"
  }
}
